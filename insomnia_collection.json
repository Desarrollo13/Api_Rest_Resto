{
  "_type": "export",
  "__export_format": 4,
  "resources": [
    {
      "_type": "environment",
      "_id": "env_1",
      "name": "Restaurante API",
      "data": {
        "base_url": "http://localhost:8000/api",
        "access_token": "",
        "refresh_token": ""
      }
    },
    {
      "_type": "request_group",
      "_id": "grp_auth",
      "name": "🔐 Auth",
      "parentId": null
    },
    {
      "_type": "request",
      "_id": "req_login",
      "parentId": "grp_auth",
      "name": "Login",
      "method": "POST",
      "url": "{{ _.base_url }}/auth/token/",
      "body": {
        "mimeType": "application/json",
        "text": "{\"username\": \"admin\", \"password\": \"1234\"}"
      },
      "headers": [{"name": "Content-Type", "value": "application/json"}]
    },
    {
      "_type": "request",
      "_id": "req_refresh",
      "parentId": "grp_auth",
      "name": "Refresh Token",
      "method": "POST",
      "url": "{{ _.base_url }}/auth/refresh/",
      "body": {
        "mimeType": "application/json",
        "text": "{\"refresh\": \"{{ _.refresh_token }}\"}"
      },
      "headers": [{"name": "Content-Type", "value": "application/json"}]
    },
    {
      "_type": "request",
      "_id": "req_logout",
      "parentId": "grp_auth",
      "name": "Logout",
      "method": "POST",
      "url": "{{ _.base_url }}/auth/logout/",
      "body": {
        "mimeType": "application/json",
        "text": "{\"refresh\": \"{{ _.refresh_token }}\"}"
      },
      "headers": [
        {"name": "Content-Type", "value": "application/json"},
        {"name": "Authorization", "value": "Bearer {{ _.access_token }}"}
      ]
    },
    {
      "_type": "request_group",
      "_id": "grp_menu",
      "name": "🍽️ Menú",
      "parentId": null
    },
    {
      "_type": "request",
      "_id": "req_menu_list",
      "parentId": "grp_menu",
      "name": "Listar menú (público)",
      "method": "GET",
      "url": "{{ _.base_url }}/menu/",
      "headers": []
    },
    {
      "_type": "request",
      "_id": "req_menu_create",
      "parentId": "grp_menu",
      "name": "Crear item menú (admin/gerente)",
      "method": "POST",
      "url": "{{ _.base_url }}/menu/",
      "body": {
        "mimeType": "application/json",
        "text": "{\"nombre\": \"Milanesa\", \"precio\": \"850.00\", \"disponible\": true, \"categoria\": 1}"
      },
      "headers": [
        {"name": "Content-Type", "value": "application/json"},
        {"name": "Authorization", "value": "Bearer {{ _.access_token }}"}
      ]
    },
    {
      "_type": "request_group",
      "_id": "grp_mesas",
      "name": "🪑 Mesas",
      "parentId": null
    },
    {
      "_type": "request",
      "_id": "req_mesas_list",
      "parentId": "grp_mesas",
      "name": "Listar mesas",
      "method": "GET",
      "url": "{{ _.base_url }}/mesas/",
      "headers": [{"name": "Authorization", "value": "Bearer {{ _.access_token }}"}]
    },
    {
      "_type": "request",
      "_id": "req_mesas_create",
      "parentId": "grp_mesas",
      "name": "Crear mesa (admin/gerente)",
      "method": "POST",
      "url": "{{ _.base_url }}/mesas/",
      "body": {
        "mimeType": "application/json",
        "text": "{\"numero\": 1, \"capacidad\": 4}"
      },
      "headers": [
        {"name": "Content-Type", "value": "application/json"},
        {"name": "Authorization", "value": "Bearer {{ _.access_token }}"}
      ]
    },
    {
      "_type": "request_group",
      "_id": "grp_ordenes",
      "name": "📋 Órdenes",
      "parentId": null
    },
    {
      "_type": "request",
      "_id": "req_ordenes_list",
      "parentId": "grp_ordenes",
      "name": "Listar órdenes",
      "method": "GET",
      "url": "{{ _.base_url }}/ordenes/",
      "headers": [{"name": "Authorization", "value": "Bearer {{ _.access_token }}"}]
    },
    {
      "_type": "request",
      "_id": "req_ordenes_create",
      "parentId": "grp_ordenes",
      "name": "Crear orden",
      "method": "POST",
      "url": "{{ _.base_url }}/ordenes/",
      "body": {
        "mimeType": "application/json",
        "text": "{\"mesa\": 1, \"items\": [{\"menu_item\": 1, \"cantidad\": 2, \"nota\": \"sin cebolla\"}]}"
      },
      "headers": [
        {"name": "Content-Type", "value": "application/json"},
        {"name": "Authorization", "value": "Bearer {{ _.access_token }}"}
      ]
    },
    {
      "_type": "request",
      "_id": "req_ordenes_estado",
      "parentId": "grp_ordenes",
      "name": "Cambiar estado orden",
      "method": "PATCH",
      "url": "{{ _.base_url }}/ordenes/1/estado/",
      "body": {
        "mimeType": "application/json",
        "text": "{\"estado\": \"en_cocina\"}"
      },
      "headers": [
        {"name": "Content-Type", "value": "application/json"},
        {"name": "Authorization", "value": "Bearer {{ _.access_token }}"}
      ]
    }
  ]
}